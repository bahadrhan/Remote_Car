#include "sensors/UltrasonicSensor.hpp"

#include "hw/BoardPins.hpp"
#include "hw/Clock.hpp"
#include "hw/Gpio.hpp"
#include "hw/Timebase.hpp"

void UltrasonicSensor::init()
{
    Clock::enableGpioClock(BoardPins::US_TRIG_PORT);
    Clock::enableGpioClock(BoardPins::US_ECHO_PORT);

    Gpio::configureOutput(BoardPins::US_TRIG_PORT, BoardPins::US_TRIG_PIN);
    Gpio::configureInput (BoardPins::US_ECHO_PORT, BoardPins::US_ECHO_PIN, Gpio::Pull::Down);

    Gpio::setLow(BoardPins::US_TRIG_PORT, BoardPins::US_TRIG_PIN);

    Timebase::delayMs(50);
}

void UltrasonicSensor::trigPulse10us_()
{
    Gpio::setHigh(BoardPins::US_TRIG_PORT, BoardPins::US_TRIG_PIN);
    Timebase::delayUs(10);
    Gpio::setLow(BoardPins::US_TRIG_PORT, BoardPins::US_TRIG_PIN);
}

bool UltrasonicSensor::waitForLevel_(bool high, uint32_t timeout_us)
{
    const uint32_t t0 = Timebase::micros();
    while ((uint32_t)(Timebase::micros() - t0) < timeout_us)
    {
        const bool level = Gpio::read(BoardPins::US_ECHO_PORT, BoardPins::US_ECHO_PIN);
        if (level == high) return true;
    }
    return false;
}

uint32_t UltrasonicSensor::measureEchoHighUs_(uint32_t timeout_us)
{
    if (!waitForLevel_(true, timeout_us))
        return 0;

    const uint32_t tRise = Timebase::micros();

    if (!waitForLevel_(false, timeout_us))
        return 0;

    const uint32_t tFall = Timebase::micros();
    return (uint32_t)(tFall - tRise);
}

uint32_t UltrasonicSensor::usToMm_(uint32_t echo_high_us)
{
    return (echo_high_us * 10u) / 58u;
}

bool UltrasonicSensor::measureOnce(uint32_t& distance_mm)
{
    distance_mm = 0;

    trigPulse10us_();

    const uint32_t echo_us = measureEchoHighUs_(30000);
    if (echo_us == 0)
        return false;

    distance_mm = usToMm_(echo_us);
    return true;
}
