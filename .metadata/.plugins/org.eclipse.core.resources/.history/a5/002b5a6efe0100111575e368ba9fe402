#include "stm32f0xx.h"

#include <cstdint>
#include <cstring>
#include <cstdlib>
#include <cstdio>

#include "hw/Clock.hpp"
#include "hw/Timebase.hpp"
#include "hw/BoardPins.hpp"
#include "hw/Gpio.hpp"
#include "hw/Uart.hpp"

#include "app/Parameters.hpp"
