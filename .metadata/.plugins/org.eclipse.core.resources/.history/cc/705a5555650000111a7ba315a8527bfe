#include "stm32f0xx.h"

#include "hw/BoardPins.hpp"
#include "hw/Clock.hpp"
#include "hw/Gpio.hpp"
#include "hw/Timebase.hpp"

enum class LedStep : uint8_t
{
    StopOn = 0,
    StopOff,
    HeadOn,
    HeadOff,
    Count
};

static inline bool buttonDown()
{
    return !Gpio::read(BoardPins::BTN_PORT, BoardPins::BTN_PIN);
}

static inline void applyStep(LedStep s)
{
    switch (s)
    {
    case LedStep::StopOn:
        Gpio::setHigh(BoardPins::STOPLIGHT_PORT, BoardPins::STOPLIGHT_PIN);
        break;
    case LedStep::StopOff:
        Gpio::setLow(BoardPins::STOPLIGHT_PORT, BoardPins::STOPLIGHT_PIN);
        break;
    case LedStep::HeadOn:
        Gpio::setHigh(BoardPins::HEADLIGHT_PORT, BoardPins::HEADLIGHT_PIN);
        break;
    case LedStep::HeadOff:
        Gpio::setLow(BoardPins::HEADLIGHT_PORT, BoardPins::HEADLIGHT_PIN);
        break;
    default:
        break;
    }
}

int main()
{
    Clock::init48MHz_HSI48();
    Timebase::init();

    Clock::enableGpioClock(BoardPins::BTN_PORT);
    Gpio::configureInput(BoardPins::BTN_PORT, BoardPins::BTN_PIN, Gpio::Pull::Up);

    Clock::enableGpioClock(BoardPins::STOPLIGHT_PORT);
    Clock::enableGpioClock(BoardPins::HEADLIGHT_PORT);

    Gpio::configureOutput(BoardPins::STOPLIGHT_PORT, BoardPins::STOPLIGHT_PIN);
    Gpio::configureOutput(BoardPins::HEADLIGHT_PORT, BoardPins::HEADLIGHT_PIN);

    Gpio::setLow(BoardPins::STOPLIGHT_PORT, BoardPins::STOPLIGHT_PIN);
    Gpio::setLow(BoardPins::HEADLIGHT_PORT, BoardPins::HEADLIGHT_PIN);

    LedStep step = LedStep::StopOn;
    bool last = false;

    while (1)
    {
        bool down = buttonDown();

        if (down && !last)
        {
            Timebase::delayMs(30);
            if (buttonDown())
            {
                applyStep(step);

                step = static_cast<LedStep>(
                    (static_cast<uint8_t>(step) + 1u) % static_cast<uint8_t>(LedStep::Count));

                while (buttonDown())
                    Timebase::delayMs(5);
            }
        }

        last = down;
        Timebase::delayMs(5);
    }
}
