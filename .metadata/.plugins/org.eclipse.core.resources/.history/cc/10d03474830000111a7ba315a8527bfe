static bool buttonDown()
{
    // PC13 active-low
    return !Gpio::read(BoardPins::BTN_PORT, BoardPins::BTN_PIN);
}

static bool startsWith(const char* s, const char* pfx)
{
    return std::strncmp(s, pfx, std::strlen(pfx)) == 0;
}

// Read a '\n' terminated line from UART into out[]
// Returns true when a full line is available.
static bool uartReadLine(char* out, size_t maxLen)
{
    static size_t idx = 0;

    uint8_t b = 0;
    while (Uart::readByte(b))
    {
        char c = static_cast<char>(b);

        if (c == '\r')
            continue;

        if (c == '\n')
        {
            out[idx] = '\0';
            idx = 0;
            return true;
        }

        if (idx < maxLen - 1)
            out[idx++] = c;
    }

    return false;
}

static void handleLine(const char* line, CommandExecutor& exec)
{
    // --- Motion ---
    if (startsWith(line, "CMD "))
    {
        const char x = line[4];

        Command cmd{};
        cmd.value = 0;

        if      (x == 'F') cmd.type = CommandType::Forward;
        else if (x == 'B') cmd.type = CommandType::Backward;
        else if (x == 'L') cmd.type = CommandType::TurnLeft;
        else if (x == 'R') cmd.type = CommandType::TurnRight;
        else if (x == 'S') cmd.type = CommandType::Stop;
        else return;

        exec.apply(cmd);
        return;
    }

    // --- Speed ---
    if (startsWith(line, "SPD "))
    {
        int v = std::atoi(line + 4);
        if (v < 0) v = 0;
        if (v > 100) v = 100;

        exec.apply({CommandType::SetSpeed, static_cast<uint8_t>(v)});
        return;
    }

    // --- Lights enable/disable ---
    if (startsWith(line, "LIGHT "))
    {
        int en = std::atoi(line + 6);
        exec.apply({CommandType::EnableLights, static_cast<uint8_t>(en ? 1 : 0)});
        return;
    }

    // Unknown command -> optional debug
    // Uart::write("ERR\n");
}

int main()
{
    Clock::init48MHz_HSI48();
    Timebase::init();

    // Button
    Clock::enableGpioClock(BoardPins::BTN_PORT);
    Gpio::configureInput(BoardPins::BTN_PORT, BoardPins::BTN_PIN, Gpio::Pull::None);

    // UART init
    Uart::init(115200);
    Uart::write("STM32 READY\n");

    // Motor + lights
    MotorDriver motor;
    motor.init();
    motor.enable();

    Lights lights;
    lights.init();

    // Parameters
    Parameters params;
    params.defaultSpeedPercent = 60;
    params.lightsEnabled = true;
    params.sensorsEnabled = true;
    params.autoModeEnabled = false; // not used here

    // Executor
    CommandExecutor exec;
    exec.init(motor, lights, params);

    exec.apply({CommandType::Stop, 0});
    Uart::write("STOP\n");

    char line[64];

    while (1)
    {
        // Emergency stop while button held
        if (buttonDown())
        {
            exec.apply({CommandType::Stop, 0});
        }

        // UART parsing
        if (uartReadLine(line, sizeof(line)))
        {
            handleLine(line, exec);
        }

        Timebase::delayMs(5);
    }
}
