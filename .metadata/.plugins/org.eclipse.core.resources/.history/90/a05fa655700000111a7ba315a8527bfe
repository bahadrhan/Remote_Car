#include "stm32f0xx.h"

#include "hw/Clock.hpp"
#include "hw/Timebase.hpp"
#include "hw/BoardPins.hpp"
#include "hw/Gpio.hpp"

#include "sensors/UltrasonicSensor.hpp"

static inline void stopOn()
{
    Gpio::setHigh(BoardPins::STOPLIGHT_PORT, BoardPins::STOPLIGHT_PIN);
}

static inline void stopOff()
{
    Gpio::setLow(BoardPins::STOPLIGHT_PORT, BoardPins::STOPLIGHT_PIN);
}

int main()
{
    Clock::init48MHz_HSI48();
    Timebase::init();

    Clock::enableGpioClock(BoardPins::STOPLIGHT_PORT);
    Gpio::configureOutput(BoardPins::STOPLIGHT_PORT, BoardPins::STOPLIGHT_PIN);
    stopOff();

    UltrasonicSensor rear(
        BoardPins::US_REAR_TRIG_PORT,
        BoardPins::US_REAR_TRIG_PIN,
        BoardPins::US_REAR_ECHO_PORT,
        BoardPins::US_REAR_ECHO_PIN
    );

    rear.init();

    const uint32_t on_mm  = 250;
    const uint32_t off_mm = 330;

    bool stopLight = false;

    while (1)
    {
        uint32_t dist = 0;
        bool ok = rear.measureOnce(dist);

        if (!ok || dist == 0 || dist > 4000)
        {
            stopLight = false;
            stopOff();
            Timebase::delayMs(200);
            continue;
        }

        if (!stopLight)
        {
            if (dist <= on_mm)
            {
                stopLight = true;
                stopOn();
            }
        }
        else
        {
            if (dist >= off_mm)
            {
                stopLight = false;
                stopOff();
            }
        }

        Timebase::delayMs(150);
    }
}
