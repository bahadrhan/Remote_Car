#include "hw/Uart.hpp"
#include "hw/BoardPins.hpp"
#include "hw/Clock.hpp"
#include "stm32f0xx.h"

namespace
{
    // If your Clock::init48MHz_HSI48() sets SYSCLK=48MHz and APB1 prescaler=1,
    // USART2 runs from PCLK1 = 48 MHz.
    constexpr uint32_t PCLK1_HZ = 48000000u;

    inline void configurePa2Pa3_AsUsart2Af()
    {
        // Enable GPIOA clock
        RCC->AHBENR |= RCC_AHBENR_GPIOAEN;

        // Set PA2, PA3 to Alternate Function mode (MODER = 10)
        // Clear bits first
        GPIOA->MODER &= ~((3u << (2 * 2)) | (3u << (3 * 2)));
        GPIOA->MODER |=  ((2u << (2 * 2)) | (2u << (3 * 2)));

        // Optional but recommended:
        // PA3 RX pull-up to avoid floating line when disconnected
        GPIOA->PUPDR &= ~((3u << (2 * 2)) | (3u << (3 * 2)));
        GPIOA->PUPDR |=  (1u << (3 * 2)); // PA3 pull-up, PA2 no-pull

        // Set AF for PA2/PA3 = AF1 (USART2 on STM32F0)
        // AFRL covers pins 0..7, each pin has 4 bits
        GPIOA->AFR[0] &= ~((0xFu << (4 * 2)) | (0xFu << (4 * 3)));
        GPIOA->AFR[0] |=  ((1u   << (4 * 2)) | (1u   << (4 * 3)));

        // Optional: high speed
        GPIOA->OSPEEDR |= (3u << (2 * 2)) | (3u << (3 * 2));
    }

    inline void configureUsart2(uint32_t baud)
    {
        // Enable USART2 clock on APB1
        RCC->APB1ENR |= RCC_APB1ENR_USART2EN;

        // Select USART2 clock source (keep it simple: PCLK)
        // On many STM32F0: RCC->CFGR3 USART2SW bits -> 00 = PCLK
#ifdef RCC_CFGR3_USART2SW
        RCC->CFGR3 &= ~RCC_CFGR3_USART2SW;
#endif

        USART2->CR1 = 0; // disable + reset important bits

        // 8N1: default is fine (M=0, PCE=0, STOP=00)
        USART2->CR2 = 0;
        USART2->CR3 = 0;

        // Baud rate
        // BRR = fCK / baud  (oversampling by 16 on F0 when OVER8=0)
        const uint32_t brr = (PCLK1_HZ + (baud / 2u)) / baud; // rounded
        USART2->BRR = brr;

        // Enable TX, RX, USART
        USART2->CR1 |= USART_CR1_TE | USART_CR1_RE;
        USART2->CR1 |= USART_CR1_UE;

        // A short delay or dummy read can help on some setups; usually not required.
        (void)USART2->ISR;
    }
}

namespace Uart
{
    void init(uint32_t baud)
    {
        configurePa2Pa3_AsUsart2Af();
        configureUsart2(baud);
    }

    void writeByte(uint8_t b)
    {
        // Wait until TX data register empty
        while ((USART2->ISR & USART_ISR_TXE) == 0) {}
        USART2->TDR = b;
    }

    void write(const char* s)
    {
        while (*s)
        {
            if (*s == '\n') writeByte('\r');
            writeByte(static_cast<uint8_t>(*s));
            ++s;
        }
    }

    bool readByte(uint8_t& out)
    {
        // RXNE: received data ready
        if (USART2->ISR & USART_ISR_RXNE)
        {
            out = static_cast<uint8_t>(USART2->RDR);
            return true;
        }
        return false;
    }
}
